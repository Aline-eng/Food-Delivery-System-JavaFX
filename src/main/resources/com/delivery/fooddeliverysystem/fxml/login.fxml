<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.delivery.fooddeliverysystem.controller.LoginController"
      alignment="CENTER" spacing="0"
      stylesheets="@style.css"
      style="-fx-background-color: #f5f5f5;">

    <StackPane VBox.vgrow="ALWAYS" alignment="CENTER">
        <VBox alignment="CENTER" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 16, 0, 0, 4);"
              maxWidth="380" maxHeight="440">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

            <!-- Logo / Title -->
            <Label text="🍔 FoodDash" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e65c00;"/>
            <Label text="Sign in to your account" style="-fx-font-size: 13px; -fx-text-fill: #888888; -fx-padding: 4 0 28 0;"/>

            <!-- Username -->
            <Label text="Username" styleClass="form-label" style="-fx-padding: 0 0 4 0;"/>
            <TextField fx:id="fieldUsername" promptText="Enter your username" maxWidth="Infinity"/>

            <!-- Password -->
            <Label text="Password" styleClass="form-label" style="-fx-padding: 14 0 4 0;"/>
            <PasswordField fx:id="fieldPassword" promptText="Enter your password" maxWidth="Infinity"/>

            <!-- Error message -->
            <Label fx:id="loginMsg" text="" wrapText="true" maxWidth="300"
                   style="-fx-padding: 10 0 0 0;" styleClass="msg-error"/>

            <!-- Login button -->
            <Button text="Sign In" styleClass="btn-primary" maxWidth="Infinity"
                    style="-fx-padding: 12 0; -fx-font-size: 14px; -fx-margin: 20 0 0 0;"
                    onAction="#handleLogin">
                <VBox.margin><Insets top="20"/></VBox.margin>
            </Button>

            <!-- Signup link -->
            <HBox alignment="CENTER" spacing="4" style="-fx-padding: 16 0 0 0;">
                <Label text="Don't have an account?" style="-fx-text-fill: #888888;"/>
                <Button text="Sign Up" styleClass="btn-link" onAction="#goToSignup"
                        style="-fx-background-color: transparent; -fx-text-fill: #e65c00; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 0;"/>
            </HBox>
        </VBox>
    </StackPane>
</VBox>
