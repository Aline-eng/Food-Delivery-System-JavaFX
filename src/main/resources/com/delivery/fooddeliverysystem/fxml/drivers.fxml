<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.delivery.fooddeliverysystem.controller.DriverController"
      spacing="15" stylesheets="@../css/style.css">

    <!-- Form -->
    <VBox styleClass="content-panel" spacing="12">
        <Label text="Manage Delivery Drivers" styleClass="section-title"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Driver ID" styleClass="form-label"/>
                <TextField fx:id="fieldId" promptText="e.g. D-001"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Name" styleClass="form-label"/>
                <TextField fx:id="fieldName" promptText="Full name"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Phone" styleClass="form-label"/>
                <TextField fx:id="fieldPhone" promptText="e.g. 0700000000"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Vehicle Type" styleClass="form-label"/>
                <TextField fx:id="fieldVehicle" promptText="e.g. Motorcycle"/>
            </VBox>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="Add Driver" styleClass="btn-primary" onAction="#addDriver"/>
            <Button text="Remove Selected" styleClass="btn-danger" onAction="#removeDriver"/>
            <Label fx:id="driverMsg" styleClass="msg-success"/>
        </HBox>
    </VBox>

    <!-- Table -->
    <VBox styleClass="content-panel" spacing="10" VBox.vgrow="ALWAYS">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Drivers" styleClass="section-title" HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search..." prefWidth="200"/>
            <Button text="Search" styleClass="btn-secondary" onAction="#searchDrivers"/>
            <Button text="Sort A-Z" styleClass="btn-secondary" onAction="#sortDrivers"/>
            <Button text="Refresh" styleClass="btn-secondary" onAction="#refreshDrivers"/>
        </HBox>
        <TableView fx:id="driversTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"        text="ID"          prefWidth="100"/>
                <TableColumn fx:id="colName"      text="Name"        prefWidth="160"/>
                <TableColumn fx:id="colPhone"     text="Phone"       prefWidth="130"/>
                <TableColumn fx:id="colVehicle"   text="Vehicle"     prefWidth="120"/>
                <TableColumn fx:id="colAvailable" text="Available"   prefWidth="90"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
