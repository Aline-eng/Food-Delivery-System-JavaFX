<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.delivery.fooddeliverysystem.controller.CustomerDashboardController"
            prefWidth="1000" prefHeight="660"
            stylesheets="@../css/style.css">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="2">
            <Label text="🍔 FoodDash" styleClass="sidebar-title"/>
            <Label text="Customer Portal" styleClass="sidebar-subtitle"/>
            <Separator/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Logout" styleClass="nav-button" onAction="#handleLogout"
                    style="-fx-text-fill: #ff6b6b;"/>
            <padding><Insets bottom="10"/></padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <!-- Header -->
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblWelcome" text="Welcome!" styleClass="header-title" HBox.hgrow="ALWAYS"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #f5f5f5;">
                <VBox spacing="20">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                    <!-- Order Form -->
                    <VBox styleClass="content-panel" spacing="14">
                        <Label text="🛒 Place a New Order" styleClass="section-title"/>

                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Choose Restaurant" styleClass="form-label"/>
                                <ComboBox fx:id="restaurantCombo" maxWidth="Infinity" promptText="Select a restaurant..."/>
                            </VBox>
                        </HBox>

                        <HBox spacing="15" alignment="TOP_LEFT">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Menu Items  (hold Ctrl to select multiple)" styleClass="form-label"/>
                                <ListView fx:id="menuListView" prefHeight="180"/>
                            </VBox>
                            <VBox spacing="10" alignment="TOP_RIGHT" minWidth="160">
                                <Label text="Order Total" styleClass="form-label"/>
                                <Label fx:id="lblTotal" text="$0.00"
                                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e65c00;"/>
                                <Button text="Place Order 🛒" styleClass="btn-primary"
                                        maxWidth="Infinity" onAction="#placeOrder"
                                        style="-fx-padding: 12 0;"/>
                            </VBox>
                        </HBox>

                        <Label fx:id="orderMsg" text="" wrapText="true"/>
                    </VBox>

                    <!-- My Orders -->
                    <VBox styleClass="content-panel" spacing="10" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📦 My Orders" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                            <Button text="Cancel Selected" styleClass="btn-danger" onAction="#cancelMyOrder"/>
                            <Button text="Refresh" styleClass="btn-secondary" onAction="#refreshMyOrders"/>
                        </HBox>
                        <TableView fx:id="myOrdersTable" prefHeight="220">
                            <columns>
                                <TableColumn fx:id="colId"         text="Order ID"   prefWidth="130"/>
                                <TableColumn fx:id="colRestaurant" text="Restaurant" prefWidth="140"/>
                                <TableColumn fx:id="colItems"      text="Items"      prefWidth="200"/>
                                <TableColumn fx:id="colTotal"      text="Total"      prefWidth="80"/>
                                <TableColumn fx:id="colDriver"     text="Driver"     prefWidth="110"/>
                                <TableColumn fx:id="colStatus"     text="Status"     prefWidth="120"/>
                                <TableColumn fx:id="colTime"       text="Ordered At" prefWidth="130"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
